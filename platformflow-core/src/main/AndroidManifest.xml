<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>

        <!--
            Internal SDK shell. Hosts go through PlatformFlow.start(...).
            exported=false: only this process (the host app) can launch it.
            NoActionBar so the SDK doesn't draw a host action bar over its
            overlays.
        -->
        <activity
            android:name="com.seamfix.platformflow.core.ui.PlatformFlowActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

    </application>

</manifest>
